{
  "entities": {
    "Player": {
      "title": "Player",
      "description": "A player in the club.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "tier": { "type": "string", "enum": ["BEGINNER", "LOW_INTERMEDIATE", "INTERMEDIATE", "ADVANCED"] },
        "ratingScore": { "type": "number" },
        "joinedAt": { "type": "number" },
        "hasPaid": { "type": "boolean" },
        "status": { "type": "string", "enum": ["WAITING", "PLAYING", "RESTING", "AWAY"] },
        "stats": {
          "type": "object",
          "properties": {
            "gamesPlayed": { "type": "number" },
            "wins": { "type": "number" },
            "losses": { "type": "number" },
            "currentStreak": { "type": "number" }
          }
        }
      },
      "required": ["userId", "name", "tier", "ratingScore", "joinedAt", "hasPaid", "status", "stats"]
    },
    "Court": {
      "title": "Court",
      "description": "A badminton court.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["Available", "Occupied", "Finishing Soon"] },
        "activeMatchId": { "type": ["string", "null"] },
        "queue": { 
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["userId", "name", "status", "queue"]
    },
    "Match": {
      "title": "Match",
      "description": "A match played on a court.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "courtId": { "type": "string" },
        "teamA": { "type": "array", "items": { "type": "string" } },
        "teamB": { "type": "array", "items": { "type": "string" } },
        "startTime": { "type": ["number", "null"] },
        "status": { "type": "string", "enum": ["Waiting", "Active", "Completed", "Cancelled"] },
        "scoreA": { "type": "number" },
        "scoreB": { "type": "number" },
        "shuttlecocksUsed": { "type": "number" }
      },
      "required": ["userId", "courtId", "teamA", "teamB", "status"]
    },
    "FinancialConfig": {
      "title": "FinancialConfig",
      "description": "Financial configuration for the club.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "mode": { "type": "string", "enum": ["Breakdown", "Fixed"] },
        "courtFee": { "type": "number" },
        "shuttleFee": { "type": "number" },
        "fixedRate": { "type": "number" }
      },
      "required": ["userId", "mode", "courtFee", "shuttleFee", "fixedRate"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile with skill, country, and role details.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "skillTier": { "type": "string", "enum": ["BEGINNER", "LOW_INTERMEDIATE", "INTERMEDIATE", "ADVANCED"] },
        "country": { "type": "string" },
        "role": { "type": "string", "enum": ["PLAYER", "QUEUE_MASTER"] },
        "hasSeenWelcomeModal": { "type": "boolean" },
        "profileCompleted": { "type": "boolean" },
        "ratingScore": { "type": "number" },
        "joinedAt": { "type": "number" },
        "stats": {
          "type": "object",
          "properties": {
            "gamesPlayed": { "type": "number" },
            "wins": { "type": "number" },
            "losses": { "type": "number" },
            "currentStreak": { "type": "number" }
          }
        }
      },
      "required": ["id", "name", "email", "skillTier", "country", "role", "profileCompleted", "hasSeenWelcomeModal"]
    },
    "SessionMapping": {
      "title": "SessionMapping",
      "description": "Mapping of a 6-digit Session ID to a Queue Master's User ID.",
      "type": "object",
      "properties": {
        "qmUserId": { "type": "string" },
        "active": { "type": "boolean" }
      },
      "required": ["qmUserId", "active"]
    }
  },
  "firestore": {
    "users/{userId}/players/{playerId}": {
      "schema": { "$ref": "#/entities/Player" },
      "description": "Players managed by a user."
    },
    "users/{userId}/courts/{courtId}": {
      "schema": { "$ref": "#/entities/Court" },
      "description": "Courts managed by a user."
    },
    "users/{userId}/matches/{matchId}": {
      "schema": { "$ref": "#/entities/Match" },
      "description": "Matches managed by a user."
    },
    "users/{userId}/financialConfig/default": {
      "schema": { "$ref": "#/entities/FinancialConfig" },
      "description": "Financial config for a user."
    },
    "profiles/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Global user profiles."
    },
    "sessions/{sessionId}": {
      "schema": { "$ref": "#/entities/SessionMapping" },
      "description": "Session code mapping."
    }
  }
}
