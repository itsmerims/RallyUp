rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidPlayer(data) {
      return data.keys().hasAll(['userId', 'name', 'tier', 'ratingScore', 'joinedAt', 'waitingSince', 'hasPaid', 'status', 'stats'])
        && data.userId == request.auth.uid
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.tier in ['BEG', 'ADV_BEG', 'LOW_INT', 'INT', 'MID_INT', 'UP_INT', 'ADV', 'EXP', 'PRO']
        && data.ratingScore is number
        && data.joinedAt is number
        && data.waitingSince is number
        && data.hasPaid is bool
        && data.status in ['waiting', 'active', 'resting', 'timeout']
        && data.stats is map
        && data.stats.keys().hasAll(['gamesPlayed', 'wins', 'losses', 'currentStreak'])
        && data.stats.gamesPlayed is number
        && data.stats.wins is number
        && data.stats.losses is number
        && data.stats.currentStreak is number;
    }

    function isValidAutoRegister(data, ownerId) {
      return data.keys().hasAll(['userId', 'name', 'tier', 'sessionId', 'autoRegistered'])
        && data.userId == ownerId
        && data.autoRegistered == true
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.tier in ['BEG', 'ADV_BEG', 'LOW_INT', 'INT', 'MID_INT', 'UP_INT', 'ADV', 'EXP', 'PRO']
        && data.sessionId is string;
    }

    function isValidCourt(data) {
      return data.keys().hasAll(['userId', 'name', 'status', 'queue'])
        && data.userId == request.auth.uid
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.status in ['Available', 'Occupied', 'Finishing Soon']
        && data.queue is list && data.queue.size() <= 50;
    }

    function isValidMatch(data) {
      return data.keys().hasAll(['userId', 'courtId', 'teamA', 'teamB', 'status'])
        && data.userId == request.auth.uid
        && data.courtId is string && data.courtId.size() <= 128
        && data.teamA is list && data.teamA.size() <= 2
        && data.teamB is list && data.teamB.size() <= 2
        && data.status in ['Waiting', 'Active', 'Completed', 'Cancelled']
        && (data.get('scoreA', 0) is number)
        && (data.get('scoreB', 0) is number)
        && (data.get('shuttlecocksUsed', 0) is number);
    }

    function isValidFinancialConfig(data) {
      return data.keys().hasAll(['userId', 'mode', 'courtFee', 'shuttleFee', 'fixedRate'])
        && data.userId == request.auth.uid
        && data.mode in ['Breakdown', 'Fixed']
        && data.courtFee is number
        && data.shuttleFee is number
        && data.fixedRate is number;
    }

    match /users/{userId}/players/{playerId} {
      allow read: if isSignedIn() && isValidId(playerId);
      allow list: if isSignedIn();
      allow create: if (isOwner(userId) && isValidId(playerId) && isValidPlayer(incoming()))
        || (isSignedIn() && isValidId(playerId) && isValidAutoRegister(incoming(), userId) && request.auth.uid != userId);
      allow update: if isOwner(userId) && isValidId(playerId) && isValidPlayer(incoming());
      allow delete: if isOwner(userId) && isValidId(playerId);
      // Allow anyone (including non-auth players) to subscribe for notifications
      allow update: if request.resource.data.keys().hasOnly(['fcmTokens'])
        && request.resource.data.fcmTokens is list;
    }

    match /users/{userId}/courts/{courtId} {
      allow read: if isSignedIn() && isValidId(courtId);
      allow list: if isSignedIn();
      allow create: if isOwner(userId) && isValidId(courtId) && isValidCourt(incoming());
      allow update: if isOwner(userId) && isValidId(courtId) && isValidCourt(incoming());
      allow delete: if isOwner(userId) && isValidId(courtId);
    }

    match /users/{userId}/matches/{matchId} {
      allow read: if isSignedIn() && isValidId(matchId);
      allow list: if isSignedIn();
      allow create: if isOwner(userId) && isValidId(matchId) && isValidMatch(incoming());
      allow update: if isOwner(userId) && isValidId(matchId) && isValidMatch(incoming());
      allow delete: if isOwner(userId) && isValidId(matchId);
    }

    match /users/{userId}/financialConfig/default {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId) && isValidFinancialConfig(incoming());
    }

    match /profiles/{profileUserId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(profileUserId);
      allow delete: if isOwner(profileUserId);
    }

    match /sessions/{sessionId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    function isValidClub(data) {
      return data.keys().hasAll(['name', 'description', 'ownerId', 'ownerName', 'createdAt', 'joinCode', 'memberCount'])
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.description is string && data.description.size() <= 500
        && data.ownerId == request.auth.uid
        && data.ownerName is string && data.ownerName.size() > 0
        && data.createdAt is number
        && data.joinCode is string && data.joinCode.size() >= 4 && data.joinCode.size() <= 10
        && data.memberCount is number && data.memberCount >= 1;
    }

    function isValidClubMember(data, userId) {
      return data.keys().hasAll(['role', 'joinedAt', 'name'])
        && data.role in ['owner', 'member']
        && data.joinedAt is number
        && data.name is string && data.name.size() > 0;
    }

    match /clubs/{clubId} {
      allow read: if isSignedIn() && isValidId(clubId);
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(clubId) && isValidClub(incoming());
      allow update: if isOwner(incoming().ownerId) && isValidId(clubId);
      // Allow memberCount updates from member create/delete
      allow update: if isSignedIn() && isValidId(clubId)
        && incoming().keys().hasOnly(['memberCount'])
        && incoming().memberCount is number;
      allow delete: if isOwner(get(/databases/$(database)/documents/clubs/$(clubId)).data.ownerId);
    }

    match /clubs/{clubId}/members/{userId} {
      allow read: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId && isValidClubMember(incoming(), userId);
      allow update: if request.auth.uid == userId && isValidClubMember(incoming(), userId);
      allow delete: if request.auth.uid == userId
        || request.auth.uid == get(/databases/$(database)/documents/clubs/$(clubId)).data.ownerId;
    }
  }
}
